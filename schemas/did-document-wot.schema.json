{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web-of-trust.de/schemas/did-document-wot.schema.json",
  "title": "WoT DID Document Profile",
  "type": "object",
  "required": ["id", "verificationMethod", "authentication", "assertionMethod", "keyAgreement"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
    "verificationMethod": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "controller", "publicKeyMultibase"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "controller": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
          "publicKeyMultibase": { "type": "string", "pattern": "^z[1-9A-HJ-NP-Za-km-z]+$" }
        }
      }
    },
    "authentication": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "assertionMethod": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "keyAgreement": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "controller", "publicKeyMultibase"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "controller": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
          "publicKeyMultibase": { "type": "string", "pattern": "^z[1-9A-HJ-NP-Za-km-z]+$" }
        }
      }
    },
    "service": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "serviceEndpoint"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "serviceEndpoint": { "type": "string", "minLength": 1 }
        }
      }
    },
    "capabilityDelegation": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
