{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web-of-trust.de/schemas/capability-payload.schema.json",
  "title": "WoT Capability Payload",
  "type": "object",
  "required": ["type", "spaceId", "audience", "permissions", "generation", "issuedAt", "validUntil"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "capability" },
    "spaceId": { "type": "string", "format": "uuid" },
    "audience": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["read", "write"] }
    },
    "generation": { "type": "integer", "minimum": 0 },
    "issuedAt": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" }
  }
}
